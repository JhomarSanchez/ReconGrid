{
  "name": "recongrid",
  "version": "1.0.0",
  "description": "Desktop app for Excel reconciliation and auditable exports.",
  "main": "index.js",
  "scripts": {
    "start": "electron . --max-old-space-size=4096",
    "start:large": "electron . --max-old-space-size=8192 --expose-gc",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "test": "node --test --test-isolation=none",
    "bench:matching": "node benchmarks/compare-excels.benchmark.js"
  },
  "keywords": [
    "electron",
    "excel",
    "reconciliation",
    "matching",
    "audit"
  ],
  "author": "ReconGrid",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "to-ico": "^1.0.1"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "exceljs": "^4.4.0"
  },
  "build": {
    "appId": "com.recongrid.desktop",
    "productName": "ReconGrid",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!.gitignore",
      "!.vscode",
      "!.github",
      "!docs",
      "!dist",
      "!tests",
      "!benchmarks",
      "!presentation/views/catalog-*.html",
      "!presentation/controllers/CatalogController.js",
      "!domain/usecases/ProcessCatalogUseCase.js",
      "!domain/entities/Catalog*.js",
      "!infrastructure/parsers/CatalogParser.js",
      "!infrastructure/config/**",
      "!presentation/assets/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publish": null,
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ReconGrid",
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    },
    "portable": {
      "artifactName": "ReconGrid-Portable.exe"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "pkg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "pkg": {
      "installLocation": "/Applications",
      "allowAnywhere": true,
      "allowCurrentUserHome": false,
      "allowRootDirectory": false,
      "overwriteAction": "upgrade"
    }
  }
}
